#!/usr/bin/env bash
set -euo pipefail

# Forge - Multi-tool GitOps deployment CLI
# Deploys agents, skills, and commands to Claude Code, OpenCode, Gemini CLI, Codex, and Cursor.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MANIFEST="$SCRIPT_DIR/forge.yaml"
CONFIG_FILE="$SCRIPT_DIR/forge.config.yaml"
STATE_DIR="$SCRIPT_DIR/.forge"
STATE_FILE="$STATE_DIR/state.json"

# Tool paths
CLAUDE_DIR="${CLAUDE_HOME:-$HOME/.claude}"
OPENCODE_DIR="$HOME/.config/opencode"
GEMINI_DIR="$HOME/.gemini"
CODEX_DIR="$HOME/.codex"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${GREEN}[forge]${NC} $*"; }
warn()  { echo -e "${YELLOW}[forge]${NC} $*"; }
error() { echo -e "${RED}[forge]${NC} $*" >&2; }

ensure_state() {
  mkdir -p "$STATE_DIR"
  if [[ ! -f "$STATE_FILE" ]]; then
    echo '{"deployed_version":"none","previous_version":"none","targets":{},"deployed_at":"never"}' > "$STATE_FILE"
  fi
}

# ──────────────────────────────────────────────
# GIT HELPERS
# ──────────────────────────────────────────────

current_tag()    { git -C "$SCRIPT_DIR" describe --tags --exact-match 2>/dev/null || echo "none"; }
current_sha()    { git -C "$SCRIPT_DIR" rev-parse --short HEAD; }
current_branch() { git -C "$SCRIPT_DIR" branch --show-current; }

# ──────────────────────────────────────────────
# YAML HELPERS (no external deps)
# ──────────────────────────────────────────────

# Read top-level key from forge.config.yaml
yaml_get() {
  local key="$1"
  grep "^${key}:" "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/^[^:]*:[[:space:]]*//'
}

# Check if a target is enabled in forge.yaml
target_enabled() {
  local tool="$1"
  # Find the tool block and check if enabled: true
  local found=0 val=""
  while IFS= read -r line; do
    if [[ "$line" == "  ${tool}:" ]]; then
      found=1
      continue
    fi
    if [[ $found -eq 1 ]]; then
      if [[ "$line" =~ ^[[:space:]]+enabled:[[:space:]]*(.*) ]]; then
        val="${BASH_REMATCH[1]}"
        break
      fi
      # Next tool block — stop
      if [[ "$line" =~ ^[[:space:]][[:space:]][a-z] && ! "$line" =~ ^[[:space:]][[:space:]][[:space:]][[:space:]] ]]; then
        break
      fi
    fi
  done < "$MANIFEST"
  [[ "$val" == "true" ]]
}

# List providers from forge.config.yaml
list_providers() {
  sed -n '/^providers:$/,/^[a-z]/{
    /^  [a-z].*:$/{
      s/:$//
      s/^  //
      p
    }
  }' "$CONFIG_FILE"
}

# Resolve tier (high/medium/low) to model ID for a specific provider
resolve_tier() {
  local tier="$1"
  local provider="${2:-$(yaml_get "provider")}"

  if [[ -z "$provider" ]]; then
    error "No provider configured in forge.config.yaml"
    exit 1
  fi

  local model
  model=$(sed -n "/^  ${provider}:$/,/^  [a-z]/{
    /^    ${tier}:/{
      s/^    ${tier}: *//
      p
      q
    }
  }" "$CONFIG_FILE")

  if [[ -z "$model" ]]; then
    error "No model for tier '$tier' under provider '$provider'"
    exit 1
  fi
  echo "$model"
}

# Resolve permission (read/write/execute) to tool names for a specific tool
# Usage: resolve_permission "execute" "claude" → "Glob, Grep, LS, Read, Write, Edit, Bash"
resolve_permission() {
  local perm="$1"
  local tool="$2"

  local tools
  tools=$(sed -n "/^permissions:$/,/^[a-z]/{
    /^  ${tool}:$/,/^  [a-z]/{
      /^    ${perm}:/{
        s/^    ${perm}: *//
        p
        q
      }
    }
  }" "$CONFIG_FILE")

  echo "$tools"
}

# ──────────────────────────────────────────────
# GENERIC HELPERS
# ──────────────────────────────────────────────

# Remove a path (symlink, dir, or file) safely
clean_path() {
  local p="$1"
  if [[ -L "$p" ]]; then
    rm "$p"
  elif [[ -d "$p" ]]; then
    rm -rf "$p"
  elif [[ -f "$p" ]]; then
    rm "$p"
  fi
}

# Create symlink, removing existing first
force_symlink() {
  local src="$1" dst="$2"
  clean_path "$dst"
  mkdir -p "$(dirname "$dst")"
  ln -s "$src" "$dst"
}

# Extract frontmatter value from an .md file
# Usage: fm_get "model" agents/developer.md
fm_get() {
  local key="$1" file="$2"
  grep "^${key}:" "$file" 2>/dev/null | head -1 | sed "s/^${key}: *//" || true
}

# Extract body (everything after second ---) from an .md file
fm_body() {
  local file="$1"
  awk 'BEGIN{c=0} /^---$/{c++; next} c>=2{print}' "$file"
}

# ──────────────────────────────────────────────
# DEPLOY TO CLAUDE CODE
# Agents: copy with tier resolution
# Skills, commands: symlink
# CLAUDE.md: symlink
# ──────────────────────────────────────────────

deploy_to_claude() {
  local target="$CLAUDE_DIR"
  info "${BOLD}Claude Code${NC} → $target"

  # Agents: copy with tier→model resolution
  local agent_src="$SCRIPT_DIR/agents"
  local agent_dst="$target/agents"
  if [[ -d "$agent_src" ]]; then
    clean_path "$agent_dst"
    mkdir -p "$agent_dst"

    local provider
    provider=$(yaml_get "provider")
    local count=0

    for f in "$agent_src"/*.md; do
      [[ -f "$f" ]] || continue
      local name tier resolved perm tools_resolved
      name=$(basename "$f")
      tier=$(fm_get "model" "$f")
      perm=$(fm_get "permission" "$f")

      # Start with a copy
      cp "$f" "$agent_dst/$name"

      # Resolve model tier → actual model
      if [[ "$tier" =~ ^(high|medium|low)$ ]]; then
        resolved=$(resolve_tier "$tier" "claude")
        sed -i '' "s/^model: ${tier}$/model: ${resolved}/" "$agent_dst/$name"
      fi

      # Resolve permission → tools list
      if [[ "$perm" =~ ^(read|write|execute)$ ]]; then
        tools_resolved=$(resolve_permission "$perm" "claude")
        if [[ -n "$tools_resolved" ]]; then
          sed -i '' "s/^permission: ${perm}$/tools: ${tools_resolved}/" "$agent_dst/$name"
        fi
      fi

      info "  agents/$name  ${tier}→${GREEN}${resolved:-$tier}${NC}  ${perm}→tools"
      ((count++))
    done
    info "  ${count} agents (provider: ${GREEN}claude${NC})"
  fi

  # Skills: symlink
  if [[ -d "$SCRIPT_DIR/skills" ]]; then
    force_symlink "$SCRIPT_DIR/skills" "$target/skills"
    info "  skills → symlink"
  fi

  # Commands: symlink
  if [[ -d "$SCRIPT_DIR/commands" ]]; then
    force_symlink "$SCRIPT_DIR/commands" "$target/commands"
    info "  commands → symlink"
  fi

  # CLAUDE.md: symlink
  if [[ -f "$SCRIPT_DIR/CLAUDE.md" ]]; then
    force_symlink "$SCRIPT_DIR/CLAUDE.md" "$target/CLAUDE.md"
    info "  CLAUDE.md → symlink"
  fi
}

# ──────────────────────────────────────────────
# DEPLOY TO OPENCODE
# Agents: copy with adapted frontmatter
# Skills: skip (OpenCode reads ~/.claude/skills/ by default)
# Commands: copy as-is (same markdown format)
# ──────────────────────────────────────────────

adapt_agent_opencode() {
  local src="$1" dst="$2"

  local desc tier resolved perm perm_resolved
  desc=$(fm_get "description" "$src")
  tier=$(fm_get "model" "$src")
  perm=$(fm_get "permission" "$src")

  # Resolve model tier using active provider
  local active_provider
  active_provider=$(yaml_get "provider")
  if [[ "$tier" =~ ^(high|medium|low)$ ]]; then
    resolved=$(resolve_tier "$tier" "$active_provider")
  else
    resolved="$tier"
  fi

  # Resolve permission from config
  if [[ "$perm" =~ ^(read|write|execute)$ ]]; then
    perm_resolved=$(resolve_permission "$perm" "opencode")
  else
    perm_resolved="write"
  fi

  local body
  body=$(fm_body "$src")

  cat > "$dst" <<AGENT
---
description: ${desc}
mode: subagent
model: ${resolved}
permission: ${perm_resolved}
---

${body}
AGENT
}

deploy_to_opencode() {
  local target="$OPENCODE_DIR"
  info "${BOLD}OpenCode${NC} → $target"

  # Agents: copy with adapted frontmatter
  local agent_src="$SCRIPT_DIR/agents"
  local agent_dst="$target/agents"
  if [[ -d "$agent_src" ]]; then
    clean_path "$agent_dst"
    mkdir -p "$agent_dst"

    local count=0
    for f in "$agent_src"/*.md; do
      [[ -f "$f" ]] || continue
      local name
      name=$(basename "$f")
      adapt_agent_opencode "$f" "$agent_dst/$name"
      ((count++))
    done
    info "  ${count} agents adapted"
  fi

  # Skills: skip — OpenCode reads from ~/.claude/skills/ by default
  info "  skills → using Claude Code path (default)"

  # Commands: copy as-is (same markdown format)
  local cmd_src="$SCRIPT_DIR/commands"
  local cmd_dst="$target/commands"
  if [[ -d "$cmd_src" ]]; then
    clean_path "$cmd_dst"
    mkdir -p "$cmd_dst"
    cp -R "$cmd_src"/* "$cmd_dst"/
    info "  commands → copied"
  fi
}

# ──────────────────────────────────────────────
# DEPLOY TO GEMINI CLI
# Agents: not supported
# Skills: symlink (Agent Skills standard)
# Commands: convert .md → .toml
# GEMINI.md: copy from CLAUDE.md
# ──────────────────────────────────────────────

adapt_command_gemini() {
  local src="$1" dst="$2"

  local desc
  desc=$(fm_get "description" "$src")
  [[ -z "$desc" ]] && desc=$(fm_get "name" "$src")

  local body
  body=$(fm_body "$src")
  # Replace Claude arg syntax with Gemini syntax
  body=$(echo "$body" | sed 's/\$ARGUMENTS/{{args}}/g; s/\$1/{{args}}/g')

  cat > "$dst" <<TOML
description = "${desc}"
prompt = """
${body}
"""
TOML
}

deploy_to_gemini() {
  local target="$GEMINI_DIR"
  info "${BOLD}Gemini CLI${NC} → $target"

  # Agents: not supported
  info "  agents → skipped (not supported)"

  # Skills: symlink
  if [[ -d "$SCRIPT_DIR/skills" ]]; then
    mkdir -p "$target"
    force_symlink "$SCRIPT_DIR/skills" "$target/skills"
    info "  skills → symlink (Agent Skills standard)"
  fi

  # Commands: convert md → toml
  local cmd_src="$SCRIPT_DIR/commands"
  local cmd_dst="$target/commands"
  if [[ -d "$cmd_src" ]]; then
    clean_path "$cmd_dst"
    mkdir -p "$cmd_dst"

    local count=0
    # Process flat commands
    for f in "$cmd_src"/*.md; do
      [[ -f "$f" ]] || continue
      local name
      name=$(basename "$f" .md)
      adapt_command_gemini "$f" "$cmd_dst/${name}.toml"
      ((count++))
    done
    # Process subdirectory commands (git/commit.md → git/commit.toml)
    for subdir in "$cmd_src"/*/; do
      [[ -d "$subdir" ]] || continue
      local dirname
      dirname=$(basename "$subdir")
      mkdir -p "$cmd_dst/$dirname"
      for f in "$subdir"*.md; do
        [[ -f "$f" ]] || continue
        local name
        name=$(basename "$f" .md)
        adapt_command_gemini "$f" "$cmd_dst/$dirname/${name}.toml"
        ((count++))
      done
    done
    info "  ${count} commands → toml"
  fi

  # GEMINI.md: copy from CLAUDE.md
  if [[ -f "$SCRIPT_DIR/CLAUDE.md" ]]; then
    cp "$SCRIPT_DIR/CLAUDE.md" "$target/GEMINI.md"
    info "  GEMINI.md → copied from CLAUDE.md"
  fi
}

# ──────────────────────────────────────────────
# DEPLOY TO CURSOR (project-level)
# Agents → .cursor/rules/*.md
# Skills: not supported
# Commands: not supported
# AGENTS.md: copy from CLAUDE.md
# ──────────────────────────────────────────────

adapt_agent_cursor() {
  local src="$1" dst="$2"

  local desc
  desc=$(fm_get "description" "$src")

  local body
  body=$(fm_body "$src")

  cat > "$dst" <<RULE
---
description: "${desc}"
alwaysApply: false
---

${body}
RULE
}

deploy_to_cursor() {
  # Parse cursor_projects from forge.yaml
  local projects=()
  local in_cursor=0
  while IFS= read -r line; do
    if [[ "$line" =~ ^cursor_projects: ]]; then
      in_cursor=1
      continue
    fi
    if [[ $in_cursor -eq 1 ]]; then
      if [[ "$line" =~ ^[[:space:]]*-[[:space:]]+(.*) ]]; then
        local proj="${BASH_REMATCH[1]}"
        # Expand ~ to HOME
        proj="${proj/#\~/$HOME}"
        projects+=("$proj")
      elif [[ "$line" =~ ^[a-z] ]]; then
        break
      fi
    fi
  done < "$MANIFEST"

  if [[ ${#projects[@]} -eq 0 ]]; then
    info "${BOLD}Cursor${NC} → skipped (no cursor_projects configured)"
    return
  fi

  info "${BOLD}Cursor${NC} → ${#projects[@]} project(s)"

  local agent_src="$SCRIPT_DIR/agents"

  for proj in "${projects[@]}"; do
    if [[ ! -d "$proj" ]]; then
      warn "  $proj → directory not found, skipping"
      continue
    fi

    local rules_dir="$proj/.cursor/rules"
    mkdir -p "$rules_dir"

    # Convert agents to rules
    if [[ -d "$agent_src" ]]; then
      local count=0
      for f in "$agent_src"/*.md; do
        [[ -f "$f" ]] || continue
        local name
        name=$(basename "$f")
        adapt_agent_cursor "$f" "$rules_dir/$name"
        ((count++))
      done
      info "  $proj → ${count} rules"
    fi

    # AGENTS.md from CLAUDE.md (only if not exists — don't overwrite project-specific)
    if [[ -f "$SCRIPT_DIR/CLAUDE.md" && ! -f "$proj/AGENTS.md" ]]; then
      cp "$SCRIPT_DIR/CLAUDE.md" "$proj/AGENTS.md"
      info "  $proj → AGENTS.md created"
    fi
  done
}

# ──────────────────────────────────────────────
# DEPLOY TO CODEX (OpenAI)
# Agents: not supported (uses AGENTS.md)
# Skills: symlink
# AGENTS.md: auto-generated from forge agents
# ──────────────────────────────────────────────

deploy_to_codex() {
  local target="$CODEX_DIR"
  info "${BOLD}Codex${NC} → $target"
  mkdir -p "$target"

  # Skills: symlink
  if [[ -d "$SCRIPT_DIR/skills" ]]; then
    force_symlink "$SCRIPT_DIR/skills" "$target/skills"
    info "  skills → symlink"
  fi

  # AGENTS.md: auto-generated
  generate_agents_md "$target/AGENTS.md"
  info "  AGENTS.md → generated from forge agents"
}

# ──────────────────────────────────────────────
# GENERATE AGENTS.md
# Compiles all forge agents into a single
# AGENTS.md file (open standard).
# Compatible with Codex, Cursor, OpenCode, etc.
# ──────────────────────────────────────────────

generate_agents_md() {
  local output="$1"
  local agent_src="$SCRIPT_DIR/agents"

  [[ ! -d "$agent_src" ]] && return

  cat > "$output" <<'HEADER'
# AGENTS.md

> Auto-generated by [Forge](https://github.com/ernesto2108/forge).

## Available Agents

HEADER

  echo "| Agent | Role | Permission |" >> "$output"
  echo "|-------|------|------------|" >> "$output"

  for f in "$agent_src"/*.md; do
    [[ -f "$f" ]] || continue
    local name desc perm
    name=$(basename "$f" .md)
    desc=$(fm_get "description" "$f")
    perm=$(fm_get "permission" "$f")
    echo "| **${name}** | ${desc} | ${perm} |" >> "$output"
  done

  cat >> "$output" <<'FOOTER'

## Agent Boundaries

- **developer** is the ONLY agent that writes production code
- **tester** is the ONLY agent that writes test files
- **dba** is the ONLY agent that creates migrations
- **devops** is the ONLY agent that touches CI/CD, Dockerfiles, and infra configs
- **pm** is the ONLY agent that creates PRDs and manages the backlog
- Agents do NOT cross boundaries — developer never writes tests, tester never writes production code

## Orchestration

For non-trivial tasks, the orchestrator triages complexity and runs agents in order:
- **Trivial** (1-2 files): direct execution, no agents
- **Medium** (3-8 files): developer → tester → qa
- **Large** (8+ files): pm → architect → developer → tester → qa → reporter
FOOTER
}

# ──────────────────────────────────────────────
# DEPLOY (main)
# ──────────────────────────────────────────────

cmd_deploy() {
  local version="${1:-HEAD}"
  ensure_state

  info "Deploying forge..."
  echo ""

  # Save pre-install snapshot (first deploy only, all targets)
  local snapshot_dir="$STATE_DIR/pre-install"
  if [[ ! -d "$snapshot_dir/.snapshot-complete" ]]; then
    mkdir -p "$snapshot_dir"
    info "Saving pre-install snapshot of existing files..."
    local found_existing=0

    # Snapshot helper: backup_if_exists <source> <snapshot_subpath>
    snapshot_item() {
      local src="$1" dest="$snapshot_dir/$2"
      if [[ -d "$src" && ! -L "$src" ]]; then
        mkdir -p "$(dirname "$dest")"
        cp -R "$src" "$dest"
        info "  ${CYAN}saved${NC} $src"
        found_existing=1
      elif [[ -f "$src" && ! -L "$src" ]]; then
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        info "  ${CYAN}saved${NC} $src"
        found_existing=1
      fi
    }

    # Claude
    for comp in agents skills commands; do
      snapshot_item "$CLAUDE_DIR/$comp" "claude/$comp"
    done
    snapshot_item "$CLAUDE_DIR/CLAUDE.md" "claude/CLAUDE.md"

    # OpenCode
    for comp in agents commands; do
      snapshot_item "$OPENCODE_DIR/$comp" "opencode/$comp"
    done

    # Gemini
    for comp in skills commands; do
      snapshot_item "$GEMINI_DIR/$comp" "gemini/$comp"
    done
    snapshot_item "$GEMINI_DIR/GEMINI.md" "gemini/GEMINI.md"

    # Codex
    snapshot_item "$CODEX_DIR/skills" "codex/skills"
    snapshot_item "$CODEX_DIR/AGENTS.md" "codex/AGENTS.md"

    if [[ $found_existing -eq 0 ]]; then
      info "  No existing files found — clean install"
    fi
    mkdir -p "$snapshot_dir/.snapshot-complete"
    echo ""
  fi

  # Checkout specific version if requested
  if [[ "$version" != "HEAD" ]]; then
    if ! git -C "$SCRIPT_DIR" rev-parse "$version" &>/dev/null; then
      error "Version '$version' not found"
      exit 1
    fi
    warn "Checking out $version..."
    git -C "$SCRIPT_DIR" checkout "$version" --quiet
  fi

  local sha tag display_version prev_version
  sha=$(current_sha)
  tag=$(current_tag)
  display_version="${tag:-$sha}"
  prev_version=$(jq -r '.deployed_version' "$STATE_FILE" 2>/dev/null || echo "none")

  # Backup non-symlinked dirs before overwriting (all targets)
  backup_if_not_symlink() {
    local path="$1"
    if [[ -d "$path" && ! -L "$path" ]]; then
      local backup_path="${path}.backup.$(date +%Y%m%d%H%M%S)"
      warn "Backing up $path"
      mv "$path" "$backup_path"
    fi
  }

  for component in agents skills commands; do
    backup_if_not_symlink "$CLAUDE_DIR/$component"
  done
  backup_if_not_symlink "$OPENCODE_DIR/agents"
  backup_if_not_symlink "$OPENCODE_DIR/commands"

  # Deploy to each enabled target
  target_enabled claude   && deploy_to_claude
  echo ""
  target_enabled opencode && deploy_to_opencode
  echo ""
  target_enabled gemini   && deploy_to_gemini
  echo ""
  target_enabled codex    && deploy_to_codex
  echo ""
  target_enabled cursor   && deploy_to_cursor

  # Update state
  local active_provider
  active_provider=$(yaml_get "provider" 2>/dev/null || echo "unknown")

  local targets_json="{"
  target_enabled claude   && targets_json+='"claude":{"status":"deployed"},'
  target_enabled opencode && targets_json+='"opencode":{"status":"deployed"},'
  target_enabled gemini   && targets_json+='"gemini":{"status":"deployed"},'
  target_enabled codex    && targets_json+='"codex":{"status":"deployed"},'
  target_enabled cursor   && targets_json+='"cursor":{"status":"deployed"},'
  targets_json="${targets_json%,}}"

  cat > "$STATE_FILE" <<EOF
{
  "deployed_version": "$display_version",
  "deployed_sha": "$sha",
  "deployed_branch": "$(current_branch)",
  "previous_version": "$prev_version",
  "deployed_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "provider": "$active_provider",
  "targets": $targets_json
}
EOF

  echo ""
  info "Deployed ${CYAN}$display_version${NC} ($sha) to all enabled targets"
}

# ──────────────────────────────────────────────
# ROLLBACK
# ──────────────────────────────────────────────

cmd_rollback() {
  ensure_state
  local prev
  prev=$(jq -r '.previous_version' "$STATE_FILE" 2>/dev/null)

  if [[ -z "$prev" || "$prev" == "none" ]]; then
    error "No previous version to rollback to"
    exit 1
  fi

  warn "Rolling back to $prev..."
  cmd_deploy "$prev"
}

# ──────────────────────────────────────────────
# PIN / UNPIN (Claude target only — skills and agents)
# ──────────────────────────────────────────────

break_parent_symlink() {
  local component="$1"
  local top_level
  top_level=$(echo "$component" | cut -d'/' -f1)
  local parent_path="$CLAUDE_DIR/$top_level"

  [[ "$component" != *"/"* ]] && return

  if [[ -L "$parent_path" ]]; then
    local link_target
    link_target=$(readlink "$parent_path")
    warn "Breaking symlink $top_level/"
    rm "$parent_path"
    cp -R "$link_target" "$parent_path"
  fi
}

restore_parent_symlink() {
  local component="$1"
  local top_level
  top_level=$(echo "$component" | cut -d'/' -f1)
  local parent_path="$CLAUDE_DIR/$top_level"

  [[ "$component" != *"/"* ]] && return

  local has_pins
  has_pins=$(jq -r --arg prefix "$top_level/" \
    '[.targets.claude.pins // {} | to_entries[] | select(.key | startswith($prefix))] | length' \
    "$STATE_FILE" 2>/dev/null || echo "0")

  if [[ "$has_pins" == "0" && -d "$parent_path" && ! -L "$parent_path" ]]; then
    rm -rf "$parent_path"
    ln -s "$SCRIPT_DIR/$top_level" "$parent_path"
    info "Restored ${CYAN}$top_level/${NC} symlink"
  fi
}

cmd_pin() {
  local component="${1:-}" version="${2:-}"
  if [[ -z "$component" || -z "$version" ]]; then
    error "Usage: forge pin <component> <tag>"
    exit 1
  fi

  ensure_state

  if ! git -C "$SCRIPT_DIR" rev-parse "$version" &>/dev/null; then
    error "Version '$version' not found"
    exit 1
  fi

  break_parent_symlink "$component"

  local target_path="$CLAUDE_DIR/$component"
  clean_path "$target_path"
  mkdir -p "$(dirname "$target_path")"

  local obj_type
  obj_type=$(git -C "$SCRIPT_DIR" cat-file -t "$version:$component")
  if [[ "$obj_type" == "tree" ]]; then
    mkdir -p "$target_path"
    git -C "$SCRIPT_DIR" archive "$version" -- "$component" | tar -x -C "$CLAUDE_DIR"
  else
    git -C "$SCRIPT_DIR" show "$version:$component" > "$target_path"
  fi

  info "Pinned ${CYAN}$component${NC} to ${YELLOW}$version${NC}"

  local tmp
  tmp=$(mktemp)
  jq --arg comp "$component" --arg ver "$version" \
    '.targets.claude.pins[$comp] = $ver' \
    "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

cmd_unpin() {
  local component="${1:-}"
  [[ -z "$component" ]] && { error "Usage: forge unpin <component>"; exit 1; }

  local target_path="$CLAUDE_DIR/$component"
  local source="$SCRIPT_DIR/$component"
  [[ ! -e "$source" ]] && { error "Component '$component' not found in repo"; exit 1; }

  clean_path "$target_path"

  local tmp
  tmp=$(mktemp)
  jq --arg comp "$component" 'del(.targets.claude.pins[$comp])' \
    "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"

  if [[ "$component" == *"/"* ]]; then
    local obj_type
    obj_type=$(git -C "$SCRIPT_DIR" cat-file -t "HEAD:$component" 2>/dev/null || echo "missing")
    if [[ "$obj_type" == "tree" ]]; then
      mkdir -p "$target_path"
      git -C "$SCRIPT_DIR" archive HEAD -- "$component" | tar -x -C "$CLAUDE_DIR"
    elif [[ "$obj_type" != "missing" ]]; then
      git -C "$SCRIPT_DIR" show "HEAD:$component" > "$target_path"
    fi
    restore_parent_symlink "$component"
  else
    ln -s "$source" "$target_path"
    info "Unpinned ${CYAN}$component${NC}"
  fi
}

# ──────────────────────────────────────────────
# TARGETS — show or set which tools are active
# ──────────────────────────────────────────────

cmd_targets() {
  local all_targets=(claude opencode gemini codex cursor)

  if [[ $# -eq 0 ]]; then
    echo ""
    echo -e "${BOLD}Deploy targets:${NC}"
    echo ""
    for t in "${all_targets[@]}"; do
      if target_enabled "$t"; then
        echo -e "  ${GREEN}●${NC} $t"
      else
        echo -e "  ${RED}○${NC} $t"
      fi
    done
    echo ""
    echo "Usage:"
    echo "  forge targets <tool> [tool...]    set exact targets"
    echo "  forge targets --add <tool>        enable one target"
    echo "  forge targets --rm <tool>         disable one target"
    echo "  forge targets all                 enable all"
    return
  fi

  # Detect mode: --add, --rm, or set
  local mode="set"
  local tools=()

  if [[ "$1" == "--add" ]]; then
    mode="add"
    shift
    tools=("$@")
  elif [[ "$1" == "--rm" ]]; then
    mode="rm"
    shift
    tools=("$@")
  elif [[ "$1" == "all" ]]; then
    mode="set"
    tools=("${all_targets[@]}")
  else
    mode="set"
    tools=("$@")
  fi

  if [[ ${#tools[@]} -eq 0 ]]; then
    error "No targets specified"
    exit 1
  fi

  # Validate targets
  for req in "${tools[@]}"; do
    local valid=0
    for t in "${all_targets[@]}"; do
      [[ "$req" == "$t" ]] && valid=1
    done
    if [[ $valid -eq 0 ]]; then
      error "Unknown target: $req"
      error "Valid targets: ${all_targets[*]}"
      exit 1
    fi
  done

  # Apply changes
  _target_set() {
    local target="$1" value="$2"
    if [[ "$value" == "true" ]]; then
      sed -i '' "/^  ${target}:$/,/^  [a-z]/{s/enabled: false/enabled: true/;}" "$MANIFEST"
    else
      sed -i '' "/^  ${target}:$/,/^  [a-z]/{s/enabled: true/enabled: false/;}" "$MANIFEST"
    fi
  }

  case "$mode" in
    add)
      for req in "${tools[@]}"; do
        _target_set "$req" "true"
      done
      ;;
    rm)
      for req in "${tools[@]}"; do
        _target_set "$req" "false"
      done
      ;;
    set)
      for t in "${all_targets[@]}"; do
        local should_enable=false
        for req in "${tools[@]}"; do
          [[ "$req" == "$t" ]] && should_enable=true
        done
        if $should_enable; then
          _target_set "$t" "true"
        else
          _target_set "$t" "false"
        fi
      done
      ;;
  esac

  info "Targets updated:"
  for t in "${all_targets[@]}"; do
    if target_enabled "$t"; then
      echo -e "  ${GREEN}●${NC} $t"
    else
      echo -e "  ${RED}○${NC} $t"
    fi
  done
  echo ""
  info "Run ${YELLOW}forge deploy${NC} to apply."
}

# ──────────────────────────────────────────────
# PROVIDER
# ──────────────────────────────────────────────

cmd_provider() {
  local new_provider="${1:-}"

  if [[ -z "$new_provider" ]]; then
    local current
    current=$(yaml_get "provider" 2>/dev/null || echo "not set")
    echo ""
    echo -e "${CYAN}Current provider:${NC} ${GREEN}$current${NC}"
    echo ""
    echo -e "${CYAN}Available providers:${NC}"
    list_providers | while read -r p; do
      if [[ "$p" == "$current" ]]; then
        echo -e "  ${GREEN}$p${NC} (active)"
      else
        echo "  $p"
      fi
    done
    echo ""
    echo "Usage: forge provider <name>"
    return
  fi

  [[ ! -f "$CONFIG_FILE" ]] && { error "forge.config.yaml not found"; exit 1; }

  local exists
  exists=$(list_providers | grep -x "$new_provider" || true)
  if [[ -z "$exists" ]]; then
    error "Provider '$new_provider' not found in forge.config.yaml"
    cmd_provider
    exit 1
  fi

  sed -i '' "s/^provider: .*/provider: ${new_provider}/" "$CONFIG_FILE"
  info "Provider switched to ${GREEN}$new_provider${NC}"
  echo ""

  # Redeploy agents to Claude + OpenCode (the ones that use model: in frontmatter)
  info "Redeploying agents..."
  target_enabled claude && deploy_to_claude
  echo ""
  target_enabled opencode && {
    local agent_src="$SCRIPT_DIR/agents"
    local agent_dst="$OPENCODE_DIR/agents"
    if [[ -d "$agent_src" ]]; then
      clean_path "$agent_dst"
      mkdir -p "$agent_dst"
      for f in "$agent_src"/*.md; do
        [[ -f "$f" ]] || continue
        adapt_agent_opencode "$f" "$agent_dst/$(basename "$f")"
      done
      info "${BOLD}OpenCode${NC} → agents updated"
    fi
  }

  ensure_state
  local tmp
  tmp=$(mktemp)
  jq --arg prov "$new_provider" '.provider = $prov' "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"

  echo ""
  info "Done. All agents now use ${GREEN}$new_provider${NC} models."
}

# ──────────────────────────────────────────────
# STATUS
# ──────────────────────────────────────────────

cmd_status() {
  ensure_state

  echo ""
  echo -e "${BOLD}Forge Status${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  local deployed deployed_at prev active_provider
  deployed=$(jq -r '.deployed_version' "$STATE_FILE" 2>/dev/null)
  deployed_at=$(jq -r '.deployed_at' "$STATE_FILE" 2>/dev/null)
  prev=$(jq -r '.previous_version' "$STATE_FILE" 2>/dev/null)
  active_provider=$(jq -r '.provider // "not set"' "$STATE_FILE" 2>/dev/null)

  echo -e "  Repo:      $SCRIPT_DIR"
  echo -e "  Provider:  ${GREEN}$active_provider${NC}"
  echo -e "  Branch:    $(current_branch)"
  echo -e "  HEAD:      $(current_sha)"
  echo -e "  Tag:       $(current_tag)"
  echo -e "  Deployed:  ${GREEN}$deployed${NC}"
  echo -e "  Previous:  $prev"
  echo -e "  At:        $deployed_at"
  echo ""

  echo -e "${BOLD}Targets:${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # Claude Code
  local icon
  if [[ -d "$CLAUDE_DIR/agents" || -L "$CLAUDE_DIR/skills" ]]; then
    icon="${GREEN}●${NC}"
  else
    icon="${RED}○${NC}"
  fi
  printf "  %b %-12s %s\n" "$icon" "claude" "$CLAUDE_DIR"

  # Show Claude components
  for comp in agents skills commands CLAUDE.md; do
    local p="$CLAUDE_DIR/$comp"
    if [[ -L "$p" ]]; then
      printf "    %b %s (symlink)\n" "${GREEN}●${NC}" "$comp"
    elif [[ -e "$p" ]]; then
      printf "    %b %s (copy)\n" "${YELLOW}◐${NC}" "$comp"
    else
      printf "    %b %s\n" "${RED}○${NC}" "$comp"
    fi
  done

  # OpenCode
  if [[ -d "$OPENCODE_DIR/agents" ]]; then
    icon="${GREEN}●${NC}"
  else
    icon="${RED}○${NC}"
  fi
  printf "  %b %-12s %s\n" "$icon" "opencode" "$OPENCODE_DIR"

  # Gemini
  if [[ -d "$GEMINI_DIR/commands" || -L "$GEMINI_DIR/skills" ]]; then
    icon="${GREEN}●${NC}"
  else
    icon="${RED}○${NC}"
  fi
  printf "  %b %-12s %s\n" "$icon" "gemini" "$GEMINI_DIR"

  # Codex
  if [[ -L "$CODEX_DIR/skills" || -f "$CODEX_DIR/AGENTS.md" ]]; then
    icon="${GREEN}●${NC}"
  else
    icon="${RED}○${NC}"
  fi
  printf "  %b %-12s %s\n" "$icon" "codex" "$CODEX_DIR"

  echo ""
  echo -e "  ${GREEN}●${NC} deployed  ${YELLOW}◐${NC} copy/pinned  ${RED}○${NC} not deployed"

  # Tags
  local tags
  tags=$(git -C "$SCRIPT_DIR" tag --sort=-v:refname 2>/dev/null | head -5)
  if [[ -n "$tags" ]]; then
    echo ""
    echo -e "${CYAN}Recent tags:${NC}"
    echo "$tags" | while read -r t; do echo "  $t"; done
  fi
  echo ""
}

# ──────────────────────────────────────────────
# TAGS
# ──────────────────────────────────────────────

cmd_tags() {
  echo -e "${CYAN}Available versions:${NC}"
  echo ""
  git -C "$SCRIPT_DIR" tag --sort=-v:refname | while read -r t; do
    local d m
    d=$(git -C "$SCRIPT_DIR" log -1 --format='%ai' "$t" 2>/dev/null | cut -d' ' -f1)
    m=$(git -C "$SCRIPT_DIR" tag -l --format='%(subject)' "$t" 2>/dev/null)
    printf "  %-12s %s  %s\n" "$t" "$d" "$m"
  done
  [[ -z "$(git -C "$SCRIPT_DIR" tag)" ]] && warn "No tags yet."
}

# ──────────────────────────────────────────────
# DIFF
# ──────────────────────────────────────────────

cmd_diff() {
  ensure_state
  local deployed_sha
  deployed_sha=$(jq -r '.deployed_sha // "none"' "$STATE_FILE" 2>/dev/null)

  if [[ "$deployed_sha" == "none" ]]; then
    error "Nothing deployed yet"
    exit 1
  fi

  local current
  current=$(current_sha)

  if [[ "$deployed_sha" == "$current" ]]; then
    info "No changes since last deploy"
  else
    info "Changes since deploy ($deployed_sha → $current):"
    echo ""
    git -C "$SCRIPT_DIR" diff --stat "$deployed_sha"..HEAD -- agents/ skills/ commands/ CLAUDE.md
  fi
}

# ──────────────────────────────────────────────
# UNINSTALL
# ──────────────────────────────────────────────

cmd_uninstall() {
  ensure_state

  echo ""
  warn "This will remove forge from ALL targets:"
  warn "  Claude:   $CLAUDE_DIR/{agents,skills,commands,CLAUDE.md}"
  warn "  OpenCode: $OPENCODE_DIR/{agents,commands}"
  warn "  Gemini:   $GEMINI_DIR/{skills,commands,GEMINI.md}"
  warn "  Codex:    $CODEX_DIR/{skills,AGENTS.md}"
  echo ""
  read -rp "Continue? [y/N] " confirm
  [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { info "Aborted."; return; }
  echo ""

  local snapshot_dir="$STATE_DIR/pre-install"

  # Restore helper: remove forge's version, restore snapshot if exists
  restore_item() {
    local current="$1" snapshot="$snapshot_dir/$2"
    clean_path "$current"
    [[ -f "$current" && -L "$current" ]] && rm "$current"
    [[ -f "$current" && ! -L "$current" ]] || true

    if [[ -e "$snapshot" ]]; then
      if [[ -d "$snapshot" ]]; then
        cp -R "$snapshot" "$current"
      else
        cp "$snapshot" "$current"
      fi
      info "  ${GREEN}restored${NC} $current"
    else
      info "  removed $current"
    fi
  }

  # Claude
  info "${BOLD}Claude Code:${NC}"
  for comp in agents skills commands; do
    restore_item "$CLAUDE_DIR/$comp" "claude/$comp"
  done
  if [[ -L "$CLAUDE_DIR/CLAUDE.md" ]]; then
    rm "$CLAUDE_DIR/CLAUDE.md"
    if [[ -f "$snapshot_dir/claude/CLAUDE.md" ]]; then
      cp "$snapshot_dir/claude/CLAUDE.md" "$CLAUDE_DIR/CLAUDE.md"
      info "  ${GREEN}restored${NC} CLAUDE.md"
    fi
  fi

  # OpenCode
  info "${BOLD}OpenCode:${NC}"
  for comp in agents commands; do
    restore_item "$OPENCODE_DIR/$comp" "opencode/$comp"
  done

  # Gemini
  info "${BOLD}Gemini CLI:${NC}"
  for comp in skills commands; do
    restore_item "$GEMINI_DIR/$comp" "gemini/$comp"
  done
  if [[ -f "$GEMINI_DIR/GEMINI.md" ]]; then
    rm "$GEMINI_DIR/GEMINI.md"
    [[ -f "$snapshot_dir/gemini/GEMINI.md" ]] && cp "$snapshot_dir/gemini/GEMINI.md" "$GEMINI_DIR/GEMINI.md"
  fi

  # Codex
  info "${BOLD}Codex:${NC}"
  restore_item "$CODEX_DIR/skills" "codex/skills"
  if [[ -f "$CODEX_DIR/AGENTS.md" ]]; then
    rm "$CODEX_DIR/AGENTS.md"
    [[ -f "$snapshot_dir/codex/AGENTS.md" ]] && cp "$snapshot_dir/codex/AGENTS.md" "$CODEX_DIR/AGENTS.md"
  fi
  info "  removed AGENTS.md"

  # Clean AGENTS.md from repo root
  [[ -f "$SCRIPT_DIR/AGENTS.md" ]] && rm "$SCRIPT_DIR/AGENTS.md"

  rm -rf "$STATE_DIR"
  echo ""
  info "Forge uninstalled. Pre-existing files restored where snapshots existed."
  info "Run ${YELLOW}forge deploy${NC} to reinstall."
  echo ""
}

# ──────────────────────────────────────────────
# HELP
# ──────────────────────────────────────────────

cmd_help() {
  cat <<'HELP'

  Forge - Multi-tool GitOps for AI coding configuration

  Deploys agents, skills, and commands to:
    Claude Code, OpenCode, Gemini CLI, Codex, and Cursor

  USAGE:
    forge <command> [args]

  COMMANDS:
    deploy [version]     Deploy to all enabled targets (default: HEAD)
    targets [tool...]    Show or set which tools are active
    provider [name]      Show or switch AI provider (redeploys agents)
    status               Show deployment state across all tools
    rollback             Rollback to previous version
    pin <comp> <tag>     Pin a component to specific version (Claude)
    unpin <comp>         Unpin a component (Claude)
    uninstall            Remove forge from all targets
    tags                 List available versions
    diff                 Show changes since last deploy
    help                 Show this help

  EXAMPLES:
    forge targets                             # Show active tools
    forge targets claude                      # Only use Claude Code
    forge targets claude opencode             # Claude + OpenCode
    forge targets all                         # Enable all tools
    forge deploy                              # Deploy to active tools
    forge provider gemini                     # Switch to Gemini models
    forge provider local                      # Switch to local/Ollama
    forge status                              # What's deployed where?

  TARGETS:
    claude    ~/.claude/          agents + skills + commands
    opencode  ~/.config/opencode/ agents + commands
    gemini    ~/.gemini/          skills + commands (toml)
    codex     ~/.codex/           skills + AGENTS.md (auto-generated)
    cursor    per-project         rules from agents

HELP
}

# ──────────────────────────────────────────────
# MAIN
# ──────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    deploy)    cmd_deploy "$@" ;;
    targets)   cmd_targets "$@" ;;
    provider)  cmd_provider "$@" ;;
    rollback)  cmd_rollback "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    status)    cmd_status "$@" ;;
    pin)       cmd_pin "$@" ;;
    unpin)     cmd_unpin "$@" ;;
    tags)      cmd_tags "$@" ;;
    diff)      cmd_diff "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      error "Unknown command: $cmd"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
